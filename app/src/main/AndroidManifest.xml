<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Accountability texts must send silently: when the urge lock fires, a
         full-screen overlay covers everything, so opening the SMS composer
         underneath it can never be seen or sent by the user. -->
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Special permission: not requestable inline, the user grants it in system
         settings. Feeds both the screen-time patterns and the danger-window
         patrol; see ScreenTimeMonitor. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- App visibility (Android 11+). Without it getApplicationIcon/Label throw
         NameNotFoundException for apps not otherwise visible, which is why the
         "what kept you up" rows rendered without icons. Also required to list
         installed apps for the app-lock picker, and to name blocked packages.
         Play-restricted if ever published, but this is a personal build. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".CalmlyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Calmly">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Calmly.Starting"
            android:launchMode="singleTask"
            android:taskAffinity="">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.OverlayService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="focus_mode" />
        </service>

        <receiver
            android:name=".widget.CalmlyWidget"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/calmly_widget_info" />
        </receiver>

        <service
            android:name=".alarm.AlarmService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="alarm" />
        </service>

        <receiver
            android:name=".alarm.AlarmReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".alarm.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <activity
            android:name=".alarm.AlarmActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Calmly" />

        <receiver
            android:name=".widget.PanicWidget"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="app.andama.calmly.ACTION_PANIC" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/panic_widget_info" />
        </receiver>

        <receiver
            android:name=".service.QuoteReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".service.DangerHoursReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".service.DailyReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- The enforcement arm. The system re-enables this after reboot once the
             user has granted it, so App Lock keeps working across restarts with no
             extra wiring. Reads only the foreground package name, never content. -->
        <service
            android:name=".service.AppBlockerService"
            android:enabled="true"
            android:exported="false"
            android:label="Calmly App Lock"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/app_blocker_config" />
        </service>

        <activity
            android:name=".block.BlockActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Calmly" />
    </application>

</manifest>