<?xml version="1.0" encoding="utf-8"?>
<!--
    Watches which app comes to the foreground so blocked ones can be slammed shut.
    typeWindowStateChanged is the event that fires on an app switch; flagRetrieve...
    is off because we never read screen content, only the package name of the
    window that just opened.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:canPerformGestures="false"
    android:canRetrieveWindowContent="false"
    android:notificationTimeout="100"
    android:description="@string/app_blocker_description"
    android:summary="@string/app_blocker_summary" />
