<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg_card"
    android:padding="16dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_days_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAYS CLEAN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#A79CC8" />

        <TextView
            android:id="@+id/widget_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="44sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:textColor="#EFEAFB" />

        <TextView
            android:id="@+id/widget_milestone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="next milestone: 7 days"
            android:textSize="12sp"
            android:textColor="#D5C8FF"
            android:maxLines="1"
            android:ellipsize="end" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:progressDrawable="@drawable/widget_progress"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_mascot"
        android:layout_width="86dp"
        android:layout_height="86dp"
        android:layout_marginStart="8dp"
        android:src="@drawable/mascot_idle"
        android:contentDescription="Cal the axolotl" />

</LinearLayout>
