<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg_card"
    android:padding="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_days_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAYS CLEAN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#A79CC8" />

        <TextView
            android:id="@+id/widget_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="38sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:textColor="#EFEAFB" />

        <TextView
            android:id="@+id/widget_milestone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="7-day milestone in 7 days"
            android:textSize="11sp"
            android:textColor="#D5C8FF"
            android:maxLines="1"
            android:ellipsize="end" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:progressDrawable="@drawable/widget_progress"
            android:max="100"
            android:progress="0" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="6dp"
        android:gravity="center_horizontal">

        <ImageView
            android:id="@+id/widget_face"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:src="@drawable/face_neutral"
            android:contentDescription="Cal the axolotl" />

        <TextView
            android:id="@+id/widget_cal_line"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="keep going"
            android:textSize="11sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:textColor="#D5C8FF" />
    </LinearLayout>

</LinearLayout>
